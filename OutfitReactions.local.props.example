<Project>
  <PropertyGroup>
    <!-- Copy this file to OutfitReactions.local.props and adjust only for your own computer. -->
    <GameModsPath>C:\Program Files (x86)\Steam\steamapps\common\Stardew Valley\Mods</GameModsPath>

    <!-- Keep true for the usual automatic copy after every build. Set false to build only. -->
    <EnableOutfitReactionsDeploy>true</EnableOutfitReactionsDeploy>
  </PropertyGroup>
</Project>
